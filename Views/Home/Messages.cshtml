@{
    ViewData["Title"] = "Tin nhắn - Modern Love";
}

<div class="flex h-[calc(100vh-80px)] overflow-hidden bg-zinc-950">
    @* --- CỘT BÊN TRÁI: DANH SÁCH TIN NHẮN --- *@
    <div class="w-96 border-r border-zinc-800 flex flex-col bg-zinc-950">
        <div class="p-6">
            <h1 class="text-2xl font-black text-white tracking-tighter mb-6">Tin nhắn</h1>
            <div class="relative">
                <i class="material-icons absolute left-4 top-3 text-zinc-500 text-sm">search</i>
                <input type="text" placeholder="Tìm kiếm..." class="w-full bg-zinc-900 border-none rounded-2xl py-3 pl-12 pr-4 text-sm text-white focus:ring-2 focus:ring-rose-500/50" />
            </div>
        </div>
        
        <div class="flex-1 overflow-y-auto space-y-1 px-2 custom-scrollbar">
            <div id="activeChatItem" class="p-4 flex items-center gap-4 bg-rose-500/10 rounded-3xl cursor-pointer border border-rose-500/20">
                <div class="relative">
                    <img id="sideAvatar" src="/images/default-avatar.png" class="w-14 h-14 rounded-full object-cover ring-2 ring-rose-500 ring-offset-2 ring-offset-zinc-950" />
                    <div class="absolute bottom-0 right-0 w-4 h-4 bg-green-500 border-2 border-zinc-950 rounded-full"></div>
                </div>
                <div class="flex-1 min-w-0">
                    <h4 id="sideName" class="font-black text-sm text-white truncate">Đang tải...</h4>
                    <p class="text-xs text-rose-400 font-black animate-pulse">Trực tuyến</p>
                </div>
            </div>
        </div>
    </div>

    @* --- CỘT BÊN PHẢI: HỘP THOẠI --- *@
    <div class="flex-1 flex flex-col bg-zinc-900/10">
        <div class="p-5 border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-xl flex justify-between items-center z-10">
            <div class="flex items-center gap-4">
                <img id="mainAvatar" src="/images/default-avatar.png" class="w-11 h-11 rounded-full object-cover border border-zinc-700" />
                <div>
                    <h4 id="mainName" class="font-black text-white text-sm">Đang kết nối...</h4>
                    <div class="flex items-center gap-1.5">
                        <span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span>
                        <p class="text-[10px] text-green-400 font-black uppercase tracking-widest">Hoạt động</p>
                    </div>
                </div>
            </div>
        </div>

        <div id="chatBox" class="flex-1 overflow-y-auto p-8 space-y-6 flex flex-col custom-scrollbar bg-zinc-950">
            <div class="flex gap-4 max-w-[75%] animate-fade-in">
                <img id="bubbleAvatar" src="/images/default-avatar.png" class="w-8 h-8 rounded-full self-end object-cover" />
                <div class="bg-zinc-800 p-4 rounded-[2rem] rounded-bl-none border border-zinc-700 shadow-xl">
                    <p id="firstGreeting" class="text-sm text-zinc-200 leading-relaxed font-medium"></p>
                </div>
            </div>
        </div>

        <div class="p-6 bg-zinc-950 border-t border-zinc-800">
            <div class="max-w-4xl mx-auto flex items-center gap-4 bg-zinc-900 p-2 pl-4 rounded-[2.5rem] border border-zinc-800 focus-within:border-rose-500/50">
                <input id="chatInput" type="text" placeholder="Gửi tin nhắn..." class="flex-1 bg-transparent border-none focus:ring-0 text-sm text-white py-2" autocomplete="off" />
                <button id="btnSend" class="w-10 h-10 bg-rose-500 text-white rounded-full flex items-center justify-center">
                    <i class="material-icons text-sm">send</i>
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const urlParams = new URLSearchParams(window.location.search);
        const name = urlParams.get('name') || "Người dùng";
        const img = urlParams.get('img') || "/images/default-avatar.png";

        document.getElementById('mainName').innerText = name;
        document.getElementById('sideName').innerText = name;
        document.getElementById('mainAvatar').src = img;
        document.getElementById('sideAvatar').src = img;
        document.getElementById('bubbleAvatar').src = img;
        document.getElementById('firstGreeting').innerText = `Chào bạn! Mình là ${name}. 😊`;

        const input = document.getElementById('chatInput');
        const btn = document.getElementById('btnSend');
        const chatBox = document.getElementById('chatBox');

        function pushMessage() {
            const val = input.value.trim();
            if(val !== "") {
                const myMsg = `
                    <div class="flex flex-col items-end gap-2 animate-slide-up">
                        <div class="bg-gradient-to-br from-rose-500 to-pink-600 text-white p-4 rounded-[2rem] rounded-br-none shadow-lg max-w-[75%]">
                            <p class="text-sm font-medium">${val}</p>
                        </div>
                    </div>
                `;
                chatBox.insertAdjacentHTML('beforeend', myMsg);
                input.value = "";
                chatBox.scrollTo({ top: chatBox.scrollHeight, behavior: 'smooth' });
            }
        }

        btn.onclick = pushMessage;
        input.onkeypress = (e) => { if(e.key === 'Enter') pushMessage(); };
    });
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #3f3f46; border-radius: 10px; }
    
    .animate-slide-up { animation: slideUp 0.3s ease-out forwards; }
    .animate-fade-in { animation: fadeIn 0.5s ease-in forwards; }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
    @@keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
</style>
