@model DatingWebb.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa câu chuyện của bạn";
}

<div class="p-8 max-w-4xl mx-auto">
    <div class="flex justify-between items-end mb-8">
        <div>
            <h1 class="text-4xl font-black text-zinc-900">Chỉnh sửa câu chuyện của bạn</h1>
            <p class="text-zinc-400 text-sm mt-1">Hãy định hình sự hiện diện của bạn trong thế giới kết nối huyền ảo.</p>
        </div>
    </div>

    <form asp-action="UpdateProfile" method="post">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div class="md:col-span-2 relative aspect-square bg-zinc-100 rounded-[3rem] overflow-hidden group">
                <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=800" class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                    <button type="button" class="bg-white p-4 rounded-full shadow-xl"><i class="material-icons">add_a_photo</i></button>
                </div>
            </div>

            <div class="md:col-span-1 space-y-6">
                <div class="p-6 bg-zinc-50 rounded-[2rem] border border-zinc-100">
                    <label class="text-[10px] font-bold text-rose-500 uppercase tracking-widest">Tự truyện (Tiểu sử)</label>
                    <textarea asp-for="Bio" rows="4" class="w-full bg-transparent border-none focus:ring-0 mt-2 text-sm text-zinc-600 resize-none" placeholder="Chia sẻ đôi chút về bạn..."></textarea>
                    <span asp-validation-for="Bio" class="text-rose-500 text-[10px]"></span>
                </div>

                <div class="p-6 bg-zinc-50 rounded-[2rem] border border-zinc-100">
                    <label class="text-[10px] font-bold text-rose-500 uppercase tracking-widest">Sở thích</label>
                    <div class="flex flex-wrap gap-2 mt-3">
                        <span class="px-4 py-2 bg-rose-500 text-white rounded-full text-[10px] font-bold">Fine Dining</span>
                        <span class="px-4 py-2 bg-violet-500 text-white rounded-full text-[10px] font-bold">Solo Travel</span>
                        <button type="button" class="px-4 py-2 border border-dashed border-zinc-300 rounded-full text-[10px] text-zinc-400">+ Thêm</button>
                    </div>
                </div>
                
                <button type="submit" class="w-full py-4 bg-zinc-900 text-white rounded-2xl font-bold hover:bg-black transition-all">Lưu thay đổi</button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}