@model DatingWebb.Models.UserProfileViewModel
@{
    ViewData["Title"] = "Chỉnh sửa câu chuyện của bạn";
}

<div class="p-8 max-w-4xl mx-auto">
    <div class="flex justify-between items-end mb-8">
        <div>
            <h1 class="text-4xl font-black text-zinc-900 dark:text-white">Chỉnh sửa câu chuyện của bạn</h1>
            <p class="text-zinc-400 text-sm mt-1">Hãy định hình sự hiện diện của bạn trong thế giới kết nối huyền ảo.</p>
        </div>
    </div>

    @* Đảm bảo asp-action khớp với tên hàm trong HomeController *@
    <form asp-action="UpdateProfile" asp-controller="Home" method="post">
        @* Tag giúp bảo mật Form trong ASP.NET Core *@
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            @* Bên trái: Ảnh đại diện *@
            <div class="md:col-span-2 relative aspect-square bg-zinc-100 dark:bg-zinc-800 rounded-[3rem] overflow-hidden group">
                <img src="data:image/jpeg;base64," class="w-full h-full object-cover" />
                <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center cursor-pointer">
                    <button type="button" class="bg-white p-4 rounded-full shadow-xl">
                        <i class="material-icons text-zinc-900">add_a_photo</i>
                    </button>
                </div>
            </div>

            @* Bên phải: Các trường thông tin *@
            <div class="md:col-span-1 space-y-6">
                
                @* Ô nhập Tự truyện (Bio) *@
                <div class="p-6 bg-zinc-50 dark:bg-zinc-900 rounded-[2rem] border border-zinc-100 dark:border-zinc-800">
                    <label asp-for="Bio" class="text-[10px] font-bold text-rose-500 uppercase tracking-widest">Tự truyện (Tiểu sử)</label>
                    
                    @* asp-for sẽ tự tạo id và name là "Bio" để Controller nhận diện *@
                    <textarea asp-for="Bio" rows="6" 
                              class="w-full bg-transparent border-none focus:ring-0 mt-2 text-sm text-zinc-600 dark:text-zinc-300 resize-none outline-none" 
                              placeholder="Chia sẻ đôi chút về bạn..."></textarea>
                    
                    @* Hiển thị lỗi nếu có *@
                    <span asp-validation-for="Bio" class="text-rose-500 text-[10px] block mt-1"></span>
                </div>

                @* Ô hiển thị Sở thích (Mẫu) *@
                <div class="p-6 bg-zinc-50 dark:bg-zinc-900 rounded-[2rem] border border-zinc-100 dark:border-zinc-800">
                    <label class="text-[10px] font-bold text-rose-500 uppercase tracking-widest">Sở thích</label>
                    <div class="flex flex-wrap gap-2 mt-3">
                        <span class="px-4 py-2 bg-rose-500 text-white rounded-full text-[10px] font-bold">Fine Dining</span>
                        <span class="px-4 py-2 bg-violet-500 text-white rounded-full text-[10px] font-bold">Solo Travel</span>
                        <button type="button" class="px-4 py-2 border border-dashed border-zinc-300 dark:border-zinc-700 rounded-full text-[10px] text-zinc-400 hover:text-rose-500 transition-colors">
                            + Thêm
                        </button>
                    </div>
                </div>
                
                @* Nút lưu thay đổi *@
                <button type="submit" class="w-full py-4 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 rounded-2xl font-bold hover:scale-[1.02] active:scale-95 transition-all shadow-lg shadow-zinc-900/20">
                    Lưu thay đổi
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
