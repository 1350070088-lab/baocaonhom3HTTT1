@model DatingWebb.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng ký - Modern Love</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body class="bg-zinc-50 flex items-center justify-center h-screen">
    <div class="bg-white rounded-[3rem] shadow-2xl overflow-hidden flex max-w-4xl w-full h-[600px]">
        
        <div class="w-1/2 relative hidden md:block">
            <img src="https://images.unsplash.com/photo-1516589174184-c68526617af0?w=800" class="w-full h-full object-cover" alt="Couple" />
            <div class="absolute inset-0 bg-gradient-to-t from-rose-600/80 to-transparent p-12 flex flex-col justify-end text-white">
                <h2 class="text-3xl font-bold mb-4">Hãy bắt đầu hành trình vĩnh cửu của bạn ngay hôm nay.</h2>
            </div>
        </div>

        <div class="w-full md:w-1/2 p-12 flex flex-col justify-center">
            <div class="mb-6">
                <a asp-action="Index" class="text-rose-500 flex items-center text-sm font-bold mb-2">
                    <span class="material-icons text-sm mr-1">arrow_back</span> Quay lại trang chủ
                </a>
                <h2 class="text-2xl font-black mb-2 uppercase">Tạo tài khoản mới</h2>
                <p class="text-zinc-400 text-xs">Điền thông tin của bạn để tìm kiếm mảnh ghép còn lại.</p>
            </div>

            <form asp-action="Register" asp-controller="Home" method="post" class="space-y-4">
                @* Hiển thị lỗi tổng quát từ Server *@
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-xs font-bold bg-rose-50 p-2 rounded-lg"></div>

                <div>
                    <label class="text-[10px] font-bold uppercase text-zinc-400">Tên đầy đủ</label>
                    <input asp-for="FullName" placeholder="E.g. Julianne Moore" 
                           class="w-full p-4 bg-zinc-100 border-none rounded-2xl focus:ring-2 focus:ring-rose-500 outline-none transition-all" />
                    <span asp-validation-for="FullName" class="text-rose-500 text-[10px] block mt-1"></span>
                </div>

                <div>
                    <label class="text-[10px] font-bold uppercase text-zinc-400">Địa chỉ Email</label>
                    <input asp-for="Email" type="email" placeholder="julianne@example.com" 
                           class="w-full p-4 bg-zinc-100 border-none rounded-2xl focus:ring-2 focus:ring-rose-500 outline-none transition-all" />
                    <span asp-validation-for="Email" class="text-rose-500 text-[10px] block mt-1"></span>
                </div>

                <div>
                    <label class="text-[10px] font-bold uppercase text-zinc-400">Mật khẩu</label>
                    <input asp-for="Password" type="password" placeholder="********" 
                           class="w-full p-4 bg-zinc-100 border-none rounded-2xl focus:ring-2 focus:ring-rose-500 outline-none transition-all" />
                    <span asp-validation-for="Password" class="text-rose-500 text-[10px] block mt-1"></span>
                </div>

                <button type="submit" class="w-full bg-rose-500 text-white py-4 rounded-2xl font-bold shadow-lg shadow-rose-500/30 hover:bg-rose-600 transition-all flex items-center justify-center">
                    Tạo Mới <span class="material-icons ml-2">arrow_forward</span>
                </button>
            </form>
            
            <p class="mt-6 text-center text-[10px] text-zinc-400">
                Đã có tài khoản? <a href="#" class="text-rose-500 font-bold underline">Đăng nhập ngay</a>
            </p>
        </div>
    </div>

    @* Kích hoạt Client-side Validation để kiểm tra lỗi ngay khi gõ *@
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
