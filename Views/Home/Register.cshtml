@model DatingWebb.Models.RegisterViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>
<body class="bg-zinc-50 flex items-center justify-center h-screen">
    <div class="bg-white rounded-[3rem] shadow-2xl overflow-hidden flex max-w-4xl w-full h-[600px]">
        <div class="w-1/2 relative">
            <img src="https://images.unsplash.com/photo-1516589174184-c68526617af0?w=800" class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-rose-600/80 to-transparent p-12 flex flex-col justify-end text-white">
                <h2 class="text-3xl font-bold mb-4">Hãy bắt đầu hành trình vĩnh cửu của bạn ngay hôm nay.</h2>
            </div>
        </div>

        <div class="w-1/2 p-12 flex flex-col justify-center">
            <h2 class="text-2xl font-black mb-6">TẠO TÀI KHOẢN MỚI</h2>
            <form asp-action="Register" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 text-xs"></div>

                <div>
                    <label class="text-[10px] font-bold uppercase text-zinc-400">Tên đầy đủ</label>
                    <input asp-for="FullName" placeholder="E.g. Julianne Moore" class="w-full p-4 bg-zinc-100 border-none rounded-2xl focus:ring-2 focus:ring-rose-500" />
                    <span asp-validation-for="FullName" class="text-rose-500 text-[10px]"></span>
                </div>

                <div>
                    <label class="text-[10px] font-bold uppercase text-zinc-400">Địa chỉ Email</label>
                    <input asp-for="Email" placeholder="julianne@example.com" class="w-full p-4 bg-zinc-100 border-none rounded-2xl focus:ring-2 focus:ring-rose-500" />
                    <span asp-validation-for="Email" class="text-rose-500 text-[10px]"></span>
                </div>

                <div>
                    <label class="text-[10px] font-bold uppercase text-zinc-400">Mật khẩu</label>
                    <input asp-for="Password" type="password" placeholder="********" class="w-full p-4 bg-zinc-100 border-none rounded-2xl focus:ring-2 focus:ring-rose-500" />
                    <span asp-validation-for="Password" class="text-rose-500 text-[10px]"></span>
                </div>

                <button type="submit" class="w-full bg-rose-500 text-white py-4 rounded-2xl font-bold shadow-lg shadow-rose-500/30 hover:bg-rose-600 transition-all">
                    Tạo Mới →
                </button>
            </form>
        </div>
    </div>

    @* Kích hoạt Validation *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>