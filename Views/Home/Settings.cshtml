@model DatingWebb.Models.SettingsViewModel
@{
    ViewData["Title"] = "Cài đặt";
}

<div class="p-12 max-w-5xl mx-auto">
    <h1 class="text-5xl font-black mb-2">Settings</h1>
    <p class="text-zinc-400 mb-12">Fine-tune your ethereal connection experience.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        <div class="space-y-8">
            <section class="bg-zinc-50 rounded-[2.5rem] p-8">
                <h3 class="flex items-center gap-3 font-bold mb-6">
                    <span class="w-8 h-8 bg-rose-100 text-rose-500 rounded-full flex items-center justify-center"><i class="material-icons text-sm">person</i></span>
                    Account
                </h3>
                <div class="space-y-4">
                    <div>
                        <label class="text-[10px] font-bold uppercase text-zinc-400 ml-2">Email Address</label>
                        <input asp-for="Email" class="w-full p-4 bg-white border border-zinc-100 rounded-2xl mt-1 text-sm" />
                    </div>
                    <div>
                        <label class="text-[10px] font-bold uppercase text-zinc-400 ml-2">Phone Number</label>
                        <input asp-for="PhoneNumber" class="w-full p-4 bg-white border border-zinc-100 rounded-2xl mt-1 text-sm" />
                    </div>
                </div>
            </section>
        </div>

        <div class="space-y-8">
            <section class="bg-zinc-50 rounded-[2.5rem] p-8">
                <h3 class="flex items-center gap-3 font-bold mb-6">
                    <span class="w-8 h-8 bg-rose-100 text-rose-500 rounded-full flex items-center justify-center"><i class="material-icons text-sm">tune</i></span>
                    Preferences
                </h3>
                <div class="space-y-8">
                    <div>
                        <div class="flex justify-between text-sm font-bold mb-4">
                            <span>Maximum Distance</span>
                            <span class="text-rose-500">50 miles</span>
                        </div>
                        <input type="range" class="w-full accent-rose-500" />
                    </div>
                    
                    <div class="flex justify-between items-center">
                        <span class="text-sm font-bold">Dark Mode</span>
                        <button class="w-12 h-6 bg-zinc-200 rounded-full relative p-1">
                            <span class="block w-4 h-4 bg-white rounded-full shadow-sm"></span>
                        </button>
                    </div>
                </div>
            </section>
            
            <button class="w-full py-4 border-2 border-zinc-100 rounded-2xl font-black text-zinc-400 hover:bg-white hover:text-rose-500 transition-all flex items-center justify-center gap-2">
                <i class="material-icons">logout</i> LOGOUT
            </button>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}