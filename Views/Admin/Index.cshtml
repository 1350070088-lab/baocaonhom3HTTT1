@model IEnumerable<DatingWebb.Models.AppUser>

<div class="min-h-screen bg-black text-white p-8">
    <div class="max-w-7xl mx-auto">
        @* Header Section *@
        <div class="mb-10">
            <h1 class="text-4xl font-black mb-2 text-transparent bg-clip-text bg-gradient-to-r from-rose-500 to-purple-500">
                Admin Dashboard
            </h1>
            <p class="text-zinc-500 font-medium">Hệ thống quản trị và kiểm soát chỉ số Modern Love</p>
        </div>

        @* --- 1. 4 THẺ THỐNG KÊ --- *@
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
            @* Thẻ Tổng thành viên *@
            <div class="bg-zinc-900/40 border border-zinc-800/50 p-6 rounded-[2.5rem] flex items-center gap-4 hover:border-rose-500/50 transition-all group">
                <div class="w-12 h-12 bg-rose-500/10 rounded-2xl flex items-center justify-center text-rose-500 group-hover:bg-rose-500 group-hover:text-white transition-all">
                    <span class="material-icons">groups</span>
                </div>
                <div>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Tổng thành viên</p>
                    <p class="text-2xl font-black text-white">@ViewBag.TotalUsers</p>
                </div>
            </div>

            @* Thẻ Thành viên mới *@
            <div class="bg-zinc-900/40 border border-zinc-800/50 p-6 rounded-[2.5rem] flex items-center gap-4 hover:border-amber-500/50 transition-all group">
                <div class="w-12 h-12 bg-amber-500/10 rounded-2xl flex items-center justify-center text-amber-500 group-hover:bg-amber-500 group-hover:text-white transition-all">
                    <span class="material-icons">person_add</span>
                </div>
                <div>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Thành viên mới</p>
                    <p class="text-2xl font-black text-white">@ViewBag.NewUsers</p>
                </div>
            </div>

            @* Thẻ Cặp đôi *@
            <div class="bg-zinc-900/40 border border-zinc-800/50 p-6 rounded-[2.5rem] flex items-center gap-4 hover:border-pink-500/50 transition-all group">
                <div class="w-12 h-12 bg-pink-500/10 rounded-2xl flex items-center justify-center text-pink-500 group-hover:bg-pink-500 group-hover:text-white transition-all">
                    <span class="material-icons">favorite</span>
                </div>
                <div>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Cặp đôi mới</p>
                    <p class="text-2xl font-black text-white">@ViewBag.DailyMatches</p>
                </div>
            </div>

            @* Thẻ Doanh thu *@
            <div class="bg-zinc-900/40 border border-zinc-800/50 p-6 rounded-[2.5rem] flex items-center gap-4 hover:border-emerald-500/50 transition-all group">
                <div class="w-12 h-12 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-500 group-hover:bg-emerald-500 group-hover:text-white transition-all">
                    <span class="material-icons">payments</span>
                </div>
                <div>
                    <p class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest">Doanh thu</p>
                    <p class="text-2xl font-black text-white">@String.Format("{0:0,0}đ", ViewBag.Revenue)</p>
                </div>
            </div>
        </div>

        @* --- 2. BẢNG DANH SÁCH NGƯỜI DÙNG CỰC NÉT --- *@
        <div class="bg-zinc-900/30 border border-zinc-800 rounded-[2.5rem] overflow-hidden backdrop-blur-sm">
            <div class="p-8 border-b border-zinc-800 flex justify-between items-center bg-zinc-900/50">
                <div>
                    <h2 class="text-xl font-black text-white">Danh sách người dùng mới vừa "sập bẫy"</h2>
                    <p class="text-xs text-zinc-500 font-bold uppercase tracking-tighter mt-1">Cập nhật thời gian thực</p>
                </div>
                <div class="flex gap-2">
                    <span class="bg-zinc-800 text-zinc-400 px-4 py-2 rounded-xl text-xs font-bold">@Model.Count() Users</span>
                </div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="text-[11px] font-black uppercase tracking-widest text-zinc-500 bg-zinc-950/50">
                            <th class="px-8 py-5">Avatar & Tên</th>
                            <th class="px-6 py-5">Liên hệ (Email/SĐT)</th>
                            <th class="px-6 py-5">Ngày tham gia</th>
                            <th class="px-6 py-5">Trạng thái</th>
                            <th class="px-8 py-5 text-right">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-800/50">
                        @foreach (var user in Model)
                        {
                            <tr class="hover:bg-zinc-800/30 transition-all group">
                                @* 1. Avatar & Tên *@
                                <td class="px-8 py-5">
                                    <div class="flex items-center gap-4">
                                        <div class="relative">
                                            <img src="https://ui-avatars.com/api/?name=@user.FullName&background=random&color=fff" 
                                                 class="w-12 h-12 rounded-2xl border-2 border-zinc-800 group-hover:border-rose-500/50 transition-all shadow-lg" />
                                            @if (!user.IsReadByAdmin)
                                            {
                                                <span class="absolute -top-1 -right-1 flex h-3 w-3">
                                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                                                    <span class="relative inline-flex rounded-full h-3 w-3 bg-rose-500"></span>
                                                </span>
                                            }
                                        </div>
                                        <div>
                                            <p class="font-bold text-white text-base">@user.FullName</p>
                                            <p class="text-[10px] text-zinc-500 font-black uppercase tracking-tighter">ID: #@user.Id</p>
                                        </div>
                                    </div>
                                </td>

                                @* 2. Email/SĐT *@
                                <td class="px-6 py-5">
                                    <p class="text-sm font-medium text-zinc-300">@user.Email</p>
                                    <p class="text-xs text-zinc-500">098x-xxx-xxx</p> @* Sửa thành user.PhoneNumber nếu m có cột này *@
                                </td>

                                @* 3. Ngày tham gia *@
                                <td class="px-6 py-5">
                                    <p class="text-sm font-bold text-zinc-300">@user.CreatedAt.ToString("dd/MM/yyyy")</p>
                                    <p class="text-[10px] text-zinc-500 font-black uppercase">@user.CreatedAt.ToString("HH:mm")</p>
                                </td>

                                @* 4. Trạng thái *@
                                <td class="px-6 py-5">
                                    @if (!user.IsReadByAdmin)
                                    {
                                        <span class="bg-amber-500/10 text-amber-500 text-[10px] font-black px-3 py-1 rounded-lg uppercase border border-amber-500/20">Chờ duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="bg-emerald-500/10 text-emerald-500 text-[10px] font-black px-3 py-1 rounded-lg uppercase border border-emerald-500/20">Đã duyệt</span>
                                    }
                                </td>

                                @* 5. Hành động *@
                                <td class="px-8 py-5 text-right">
                                    <div class="flex justify-end gap-2">
                                        @if (!user.IsReadByAdmin)
                                        {
                                            <form asp-action="MarkAsRead" method="post" class="inline">
                                                <input type="hidden" name="id" value="@user.Id" />
                                                <button type="submit" title="Duyệt nhanh" class="p-2 bg-zinc-800 hover:bg-emerald-500 text-zinc-400 hover:text-white rounded-xl transition-all shadow-sm">
                                                    <span class="material-icons text-sm">done_all</span>
                                                </button>
                                            </form>
                                        }
                                        <button title="Xem chi tiết" class="p-2 bg-zinc-800 hover:bg-rose-500 text-zinc-400 hover:text-white rounded-xl transition-all shadow-sm">
                                            <span class="material-icons text-sm">visibility</span>
                                        </button>
                                        <button title="Khóa tài khoản" class="p-2 bg-zinc-800 hover:bg-zinc-600 text-zinc-400 hover:text-white rounded-xl transition-all shadow-sm">
                                            <span class="material-icons text-sm">block</span>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>