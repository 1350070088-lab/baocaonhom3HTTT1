@* --- BỔ SUNG: Khai báo để dùng Session --- *@
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    // Lấy tên hiển thị từ Session. Key "UserName" khớp với HomeController
    var displayName = HttpContextAccessor.HttpContext.Session.GetString("UserName");
    var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<aside class="h-screen w-64 bg-zinc-950 border-r border-zinc-800 flex flex-col p-4 gap-2">
    
    @* Phần chào mừng người dùng - Tự động cập nhật tên *@
    <div class="mb-8 px-4 py-6 border-b border-zinc-900">
        <h2 class="text-zinc-500 text-[10px] font-bold uppercase tracking-widest mb-1 italic">Chào mừng trở lại</h2>
        <p class="text-xl font-black text-white truncate" title="@displayName">
            @(string.IsNullOrEmpty(displayName) ? "Người Dùng" : displayName)
        </p> 
    </div>

    @* Danh sách Menu điều hướng *@
    <nav class="flex-1 space-y-1">
        
        @* NHÓM USER *@
        <div class="px-4 mb-2">
            <span class="text-zinc-600 text-[9px] font-black uppercase tracking-[0.2em]">Cá nhân</span>
        </div>

        <a asp-controller="Home" asp-action="Discover" 
           class="flex items-center gap-3 @(currentAction == "Discover" && currentController == "Home" ? "bg-zinc-900 text-rose-500 shadow-sm font-bold" : "text-zinc-400 hover:bg-zinc-900 hover:text-white") rounded-2xl p-3 transition-all">
            <i class="material-icons text-sm">explore</i> <span>Khám phá</span>
        </a>

        <a asp-controller="Home" asp-action="Matches" 
           class="flex items-center gap-3 @(currentAction == "Matches" ? "bg-zinc-900 text-rose-500 shadow-sm font-bold" : "text-zinc-400 hover:bg-zinc-900 hover:text-white") p-3 rounded-2xl transition-all">
            <i class="material-icons text-sm">favorite</i> <span>Tương hợp</span>
        </a>

        <a asp-controller="Home" asp-action="Messages" 
           class="flex items-center gap-3 @(currentAction == "Messages" ? "bg-zinc-900 text-rose-500 shadow-sm font-bold" : "text-zinc-400 hover:bg-zinc-900 hover:text-white") p-3 rounded-2xl transition-all">
            <i class="material-icons text-sm">chat</i> <span>Tin nhắn</span>
        </a>

        <a asp-controller="Home" asp-action="Profile" 
           class="flex items-center gap-3 @(currentAction == "Profile" ? "bg-zinc-900 text-rose-500 shadow-sm font-bold" : "text-zinc-400 hover:bg-zinc-900 hover:text-white") p-3 rounded-2xl transition-all">
            <i class="material-icons text-sm">person</i> <span>Hồ sơ</span>
        </a>

        @* --- ĐÃ THÊM LẠI MỤC CÀI ĐẶT --- *@
        <a asp-controller="Home" asp-action="Settings" 
           class="flex items-center gap-3 @(currentAction == "Settings" ? "bg-zinc-900 text-rose-500 shadow-sm font-bold" : "text-zinc-400 hover:bg-zinc-900 hover:text-white") p-3 rounded-2xl transition-all">
            <i class="material-icons text-sm">settings</i> <span>Cài đặt</span>
        </a>

        @* NHÓM QUẢN TRỊ - Chỉ hiện cho Admin *@
        @if (displayName != null && displayName.ToLower().Contains("admin")) 
        {
            <div class="px-4 mt-6 mb-2">
                <span class="text-zinc-600 text-[9px] font-black uppercase tracking-[0.2em]">Hệ thống</span>
            </div>

            <a asp-controller="Admin" asp-action="Index" 
               class="flex items-center gap-3 @(currentController == "Admin" ? "bg-zinc-800 border-l-4 border-rose-500 text-white font-bold" : "text-zinc-400 hover:bg-zinc-900 hover:text-white") p-3 rounded-2xl transition-all">
                <i class="material-icons text-sm @(currentController == "Admin" ? "text-rose-500" : "")">admin_panel_settings</i> 
                <span>Quản trị hệ thống</span>
            </a>
            
            <a href="#" class="flex items-center gap-3 text-zinc-400 hover:bg-zinc-900 hover:text-white p-3 rounded-2xl transition-all">
                <i class="material-icons text-sm">report</i> <span>Báo cáo vi phạm</span>
            </a>
        }
    </nav>
    
    @* Nút Thoát *@
    <div class="mt-auto pt-4 border-t border-zinc-900">
        <a asp-controller="Home" asp-action="Logout" 
           class="flex items-center gap-3 text-zinc-500 hover:text-rose-500 p-3 transition-all font-bold text-[10px] uppercase tracking-widest">
            <i class="material-icons text-sm">logout</i> <span>Đăng xuất</span>
        </a>
    </div>

</aside>
